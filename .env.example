# Copie este arquivo para .env.local e preencha com os valores REAIS
# NUNCA comite o .env.local (já está no .gitignore)

# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Anon key (pública, vai para o navegador - protegida pela RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (NUNCA exponha no client, só em API routes server-side)
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
